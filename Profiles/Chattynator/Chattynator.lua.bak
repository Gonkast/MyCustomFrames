},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lyssabel Dawnpetal",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lyssabel Dawnpetal says: Our endeavor is proceeding nicely, and the trader may have additional stock.",
["id"] = "s0_152",
["timestamp"] = 1783890671,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lyssabel Dawnpetal",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lyssabel Dawnpetal says: Speak to Jorvan Longmoor. His ancestors built the first homes here. I dare say you won't find a better craftsman on the island.",
["id"] = "s0_153",
["timestamp"] = 1783890672,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Jorvan Longmoor",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Jorvan Longmoor says: On your feet, boys! We got work!",
["id"] = "s0_154",
["timestamp"] = 1783890692,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lyssabel Dawnpetal",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lyssabel Dawnpetal says: Down the road, you may have need of Jorvan again. Just return to him whenever you are ready to expand your house.",
["id"] = "s0_155",
["timestamp"] = 1783890692,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lyssabel Dawnpetal",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lyssabel Dawnpetal says: I look forward to seeing more of you around town. No matter where your adventures take you, may Elune guide you back to us.",
["id"] = "s0_156",
["timestamp"] = 1783890713,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Captain Garrick",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Captain Garrick says: Alcohol and weaponry--that's a bad mix.",
["id"] = "s0_157",
["timestamp"] = 1783892922,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Meredy Huntswell",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Meredy Huntswell says: Everyone get your buffs on.",
["id"] = "s0_158",
["timestamp"] = 1783892926,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Meredy Huntswell",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Meredy Huntswell says: Mage table ready. Come and grab a bite for later.",
["id"] = "s0_159",
["timestamp"] = 1783892928,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Captain Garrick",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Captain Garrick says: Check your adventure guide if you need more information about what we'll find here.",
["id"] = "s0_160",
["timestamp"] = 1783892930,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Goldie Baronbottom",
},
["event"] = "CHAT_MSG_MONSTER_YELL",
["type"] = "MONSTER_YELL",
},
["color"] = {
["b"] = 0.250980406999588,
["g"] = 0.250980406999588,
["r"] = 1,
},
["text"] = "Goldie Baronbottom yells: Well, whadda we have here? New customers?",
["id"] = "s0_161",
["timestamp"] = 1783895116,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Goldie Baronbottom",
},
["event"] = "CHAT_MSG_MONSTER_YELL",
["type"] = "MONSTER_YELL",
},
["color"] = {
["b"] = 0.250980406999588,
["g"] = 0.250980406999588,
["r"] = 1,
},
["text"] = "Goldie Baronbottom yells: Or are ya lookin' for somethin' a little harder?",
["id"] = "s0_162",
["timestamp"] = 1783895122,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Goldie Baronbottom",
},
["event"] = "CHAT_MSG_MONSTER_YELL",
["type"] = "MONSTER_YELL",
},
["color"] = {
["b"] = 0.250980406999588,
["g"] = 0.250980406999588,
["r"] = 1,
},
["text"] = "Goldie Baronbottom yells: Show 'em what we got on tap, Aldryr!",
["id"] = "s0_163",
["timestamp"] = 1783895125,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Donna",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Donna says: Now who's the crybaby, crybaby!?",
["id"] = "s0_164",
["timestamp"] = 1783895345,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "William",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "William says: WAAAHHH!!!",
["id"] = "s0_165",
["timestamp"] = 1783895345,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Thomas Miller",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Thomas Miller says: Fresh bread for sale!",
["id"] = "s0_166",
["timestamp"] = 1783895347,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Gil",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Gil says: I wanna see the Mage Tower.",
["id"] = "s0_167",
["timestamp"] = 1783895404,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Miss Danna",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Miss Danna says: Here we have the Cathedral of Light, the center of spiritual enlightenment here in Stormwind.",
["id"] = "s0_168",
["timestamp"] = 1783895538,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Jimmy",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Jimmy says: Is it true that the paladins train here?",
["id"] = "s0_169",
["timestamp"] = 1783895545,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Miss Danna",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Miss Danna says: Yes, that is true. Paladins and priests alike train their skills and research great truths behind the walls of the Cathedral.",
["id"] = "s0_170",
["timestamp"] = 1783895553,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Miss Danna",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Miss Danna says: Children if you would please follow me, we will now be going to see the keep where King Anduin Wrynn himself sits on his throne.",
["id"] = "s0_171",
