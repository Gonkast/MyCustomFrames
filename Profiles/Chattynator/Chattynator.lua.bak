["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Alonsus Faol says: Let your inner fires burn bright, my brethren! We are called to assault the Void!",
["id"] = "s0_208",
["timestamp"] = 1783901339,
},
