["r"] = 1,
},
["text"] = "The guards' eyes are on you. Return to neutral territory.",
["id"] = "s0_451",
["timestamp"] = 1783956430,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["race"] = "Gnome",
["class"] = "HUNTER",
["name"] = "Gnomegoat",
["sex"] = 2,
},
["event"] = "CHAT_MSG_RAID_BOSS_WHISPER",
["type"] = "MONSTER_BOSS_WHISPER",
},
["color"] = {
["b"] = 0,
["g"] = 0.8666667342185974,
["r"] = 1,
},
["text"] = "The guards' eyes are on you. Return to neutral territory.",
["id"] = "s0_452",
["timestamp"] = 1783956463,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lor'themar Theron",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lor'themar Theron says: You're needed in Fairbreeze, champion. A problem with the Lightbloom.",
["id"] = "s0_453",
["timestamp"] = 1783956542,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["race"] = "Gnome",
["class"] = "HUNTER",
["name"] = "Gnomegoat",
["sex"] = 2,
},
["event"] = "CHAT_MSG_LOOT",
["type"] = "LOOT",
},
["color"] = {
["b"] = 0,
["g"] = 0.6666666865348816,
["r"] = 0,
},
["text"] = "You receive item: |cnIQ3:|Hitem:248044::::::::80:255::11:4:13573:13613:13615:6652:2:9:80:28:3085:::::|h[Reluctant Diplomat's Vambraces]|h|r",
["id"] = "s0_454",
["timestamp"] = 1783956558,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["race"] = "Gnome",
["class"] = "HUNTER",
["name"] = "Gnomegoat",
["sex"] = 2,
},
["event"] = "CHAT_MSG_LOOT",
["type"] = "LOOT",
},
["color"] = {
["b"] = 0,
["g"] = 0.6666666865348816,
["r"] = 0,
},
["text"] = "You receive item: |cnIQ2:|Hitem:250352::::::::80:255:::::::::|h[Worn Supply Bag]|h|r",
["id"] = "s0_455",
["timestamp"] = 1783956558,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["race"] = "Gnome",
["class"] = "HUNTER",
["name"] = "Gnomegoat",
["sex"] = 2,
},
["event"] = "CHAT_MSG_ACHIEVEMENT",
["type"] = "ACHIEVEMENT",
},
["color"] = {
["b"] = 0,
["g"] = 1,
["r"] = 1,
},
["text"] = "|Hplayer:Gnomegoat-Ragnaros|h[|cffaad372Gnomegoat|r]|h has earned the achievement |cffffff00|Hachievement:62273:Player-1427-0E574B9B:1:7:13:26:4294967295:4294967295:4294967295:4294967295|h[Echoes of Midnight]|h|r!",
["id"] = "s0_456",
["timestamp"] = 1783956558,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["race"] = "Gnome",
["class"] = "HUNTER",
["name"] = "Gnomegoat",
["sex"] = 2,
},
["event"] = "CHAT_MSG_LOOT",
["type"] = "LOOT",
},
["color"] = {
["b"] = 0,
["g"] = 0.6666666865348816,
["r"] = 0,
},
["text"] = "You receive item: |cnIQ2:|Hitem:263231::::::::80:255::11::1:28:3085:::::|h[Silvermoon Curio Shelves]|h|r",
["id"] = "s0_457",
["timestamp"] = 1783956558,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Grand Magister Rommath",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Grand Magister Rommath says: Use this arcane projector to keep us informed.",
["id"] = "s0_458",
["timestamp"] = 1783956577,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "High Exarch Turalyon",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "High Exarch Turalyon says: Arator, you may be needed at the Sunwell.",
["id"] = "s0_459",
["timestamp"] = 1783956585,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Arator",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Arator says: This Lightbloom might actually be of use to the Vanguard. At the very least, I need to find out.",
["id"] = "s0_460",
["timestamp"] = 1783956590,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lor'themar Theron",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lor'themar Theron says: Is everything all right, Lady Liadrin? You've said little since we arrived.",
["id"] = "s0_461",
["timestamp"] = 1783956592,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lady Liadrin",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lady Liadrin says: My apologies--my thoughts are with the Sunwell. I did not expect it to react with such... force.",
["id"] = "s0_462",
["timestamp"] = 1783956597,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "High Exarch Turalyon",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "High Exarch Turalyon says: You ask, and the Light provides. Need it be more complicated than that?",
["id"] = "s0_463",
["timestamp"] = 1783956606,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lor'themar Theron",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lor'themar Theron says: She speaks of the Sunwell, not the Light.",
["id"] = "s0_464",
["timestamp"] = 1783956612,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "High Exarch Turalyon",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "High Exarch Turalyon says: Your fount was blessed by the heart of a naaru. It is one and the same.",
["id"] = "s0_465",
["timestamp"] = 1783956616,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lor'themar Theron",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lor'themar Theron says: I suggest you hold your tongue, High Exarch. That \"fount\" you so blithely pretend to understand predates the existence of human civilization.",
["id"] = "s0_466",
["timestamp"] = 1783956622,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lor'themar Theron",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lor'themar Theron says: And in all that time, I have never heard of the Sunwell reacting with that kind of... aggression. Liadrin, what was that beam of light?",
["id"] = "s0_467",
["timestamp"] = 1783956632,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["race"] = "NightElf",
["class"] = "DEMONHUNTER",
["name"] = "Catharthes",
["sex"] = 2,
},
["event"] = "CHAT_MSG_ACHIEVEMENT",
["type"] = "ACHIEVEMENT",
},
["color"] = {
["b"] = 0,
["g"] = 1,
["r"] = 1,
},
["text"] = "|Hplayer:Catharthes-Ragnaros|h[|cffa330c9Catharthes|r]|h has earned the achievement |cffffff00|Hachievement:61506:Player-1427-08ECBBED:1:7:13:26:4294967295:4294967295:4294967295:4294967295|h[Allied Race: Haranir]|h|r!",
["id"] = "s0_468",
["timestamp"] = 1783956633,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lady Liadrin",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lady Liadrin says: I wish I knew. It holds back the Void, yet I still wonder... if the Sunwell is capable of such power, what else will it do?",
["id"] = "s0_469",
["timestamp"] = 1783956641,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lor'themar Theron",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lor'themar Theron says: That question worries me, Liadrin. Is it wrong for it to do so?",
["id"] = "s0_470",
["timestamp"] = 1783956653,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lady Liadrin",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lady Liadrin says: The effects of the Sunwell have never been malicious. It has blessed Eversong's forests with small groves of Lightbloom for years.",
["id"] = "s0_471",
["timestamp"] = 1783956658,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lor'themar Theron",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lor'themar Theron says: Small at first, but Fairbreeze now reports a problem. If the Sunwell is aggressive, what of the Lightbloom?",
["id"] = "s0_472",
["timestamp"] = 1783956668,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "High Exarch Turalyon",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "High Exarch Turalyon says: These worries will lead you nowhere, Regent Lord. As long as the Vanguard maintains the connection to the Sunwell, the Light will see us through.",
["id"] = "s0_473",
["timestamp"] = 1783956676,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "High Exarch Turalyon",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "High Exarch Turalyon says: Have faith. That is all that is needed from you.",
["id"] = "s0_474",
["timestamp"] = 1783956686,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Meredy Huntswell",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Meredy Huntswell says: I'm suddenly thirsty. Is anyone else thirsty?",
["timestamp"] = 1783962592,
["id"] = "s0_475",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
