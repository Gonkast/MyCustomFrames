["text"] = "Commander Venel Lightblood says: Keep going! Do not succumb to the darkness!",
["id"] = "s0_394",
["timestamp"] = 1783948515,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "General Amias Bellamy",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "General Amias Bellamy says: Forward! We will push back the shadows!",
["id"] = "s0_395",
["timestamp"] = 1783948530,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Alonsus Faol",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Alonsus Faol says: Hurry, Gnomegoat! We need your help against that behemoth!",
["id"] = "s0_396",
["timestamp"] = 1783948541,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "High Exarch Turalyon",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "High Exarch Turalyon says: Channel the Light from the weapons you recovered! Drive this monster back to the Void!",
["id"] = "s0_397",
["timestamp"] = 1783948571,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lady Liadrin",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lady Liadrin says: Turalyon! We must regroup at the Sunwell before it's too late!",
["id"] = "s0_398",
["timestamp"] = 1783948696,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "High Exarch Turalyon",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "High Exarch Turalyon says: Damn it all! Vanguard, fall back!",
["id"] = "s0_399",
["timestamp"] = 1783948702,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Arator",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Arator says: We made it! Light preserve us.",
["id"] = "s0_400",
["timestamp"] = 1783948740,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lady Liadrin",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lady Liadrin says: Turalyon is rallying the survivors to the Sunwell chamber.",
["id"] = "s0_401",
["timestamp"] = 1783948747,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lady Liadrin",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lady Liadrin says: We will beseech the Light once more to help us push back the Devouring Host.",
["id"] = "s0_402",
["timestamp"] = 1783948752,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lady Liadrin",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lady Liadrin says: The Sunwell brought us salvation before. We must have faith that it will happen again.",
["id"] = "s0_403",
["timestamp"] = 1783948760,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lady Liadrin",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lady Liadrin says: You are the last of the Vanguard to make it.",
["id"] = "s0_404",
["timestamp"] = 1783948784,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Unknown",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Unknown says: Arator, Gnomegoat! Defend us as we perform the ritual!",
["id"] = "s0_405",
["timestamp"] = 1783948792,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
