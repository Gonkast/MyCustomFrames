{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lyssabel Dawnpetal",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lyssabel Dawnpetal says: If you want to procure more exotic furnishings, you should speak with the Last Architect. They have connections far and wide.",
["id"] = "s0_141",
["timestamp"] = 1783888906,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lyssabel Dawnpetal",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lyssabel Dawnpetal says: We also have some... well, some smugglers who are selling items from the Horde. I promise to look the other way if you visit them.",
["id"] = "s0_142",
["timestamp"] = 1783888927,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
