},
["event"] = "CHAT_MSG_MONSTER_YELL",
["type"] = "MONSTER_YELL",
},
["color"] = {
["b"] = 0.250980406999588,
["g"] = 0.250980406999588,
["r"] = 1,
},
["text"] = "Halduron Brightwing yells: All forces, return! Dark forces are emerging. We need help closing their fissures.",
