{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Image of Lady Liadrin",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Image of Lady Liadrin says: Even with reinforcements, we cannot hold back the Devouring Host for long. Make haste, Gnomegoat.",
["id"] = "s0_173",
["timestamp"] = 1783895772,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Gil",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Gil says: Where we goin'?",
["id"] = "s0_174",
["timestamp"] = 1783895963,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Miss Danna",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Miss Danna says: Here we have the Cathedral of Light, the center of spiritual enlightenment here in Stormwind.",
["id"] = "s0_175",
["timestamp"] = 1783896360,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Jimmy",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Jimmy says: Is it true that the paladins train here?",
["id"] = "s0_176",
["timestamp"] = 1783896368,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Miss Danna",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Miss Danna says: Yes, that is true. Paladins and priests alike train their skills and research great truths behind the walls of the Cathedral.",
["id"] = "s0_177",
["timestamp"] = 1783896375,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Miss Danna",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Miss Danna says: Children if you would please follow me, we will now be going to see the keep where King Anduin Wrynn himself sits on his throne.",
["id"] = "s0_178",
["timestamp"] = 1783896380,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
