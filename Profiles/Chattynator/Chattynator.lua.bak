},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Jimmy says: Is it true that the paladins train here?",
["timestamp"] = 1783897184,
["id"] = "s0_181",
},
{
