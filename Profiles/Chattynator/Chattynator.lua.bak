{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Wenbrandt",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Wenbrandt says: Are you here to help? My zeal to get back in business lead to faulty reasoning...",
["id"] = "s0_89",
["timestamp"] = 1783884102,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Goldie Baronbottom",
},
["event"] = "CHAT_MSG_MONSTER_YELL",
["type"] = "MONSTER_YELL",
},
["color"] = {
["b"] = 0.250980406999588,
["g"] = 0.250980406999588,
["r"] = 1,
},
["text"] = "Goldie Baronbottom yells: Ya pal here signed some papers he didn't read! And now Goldie Baronbottom is Bee-E-O of this joint.",
["id"] = "s0_90",
["timestamp"] = 1783884110,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Wenbrandt",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Wenbrandt says: Ooh! You... Help me please get my meadery back, Gnomegoat!",
["id"] = "s0_91",
["timestamp"] = 1783884119,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lyssabel Dawnpetal",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Lyssabel Dawnpetal says: I do enjoy a good stroll about town. Let's see what plots are available.",
["timestamp"] = 1783885804,
["id"] = "s0_92",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lyssabel Dawnpetal",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Lyssabel Dawnpetal says: And if you have any questions or find your options are too limited, please speak with me.",
["timestamp"] = 1783885810,
["id"] = "s0_93",
},
{
