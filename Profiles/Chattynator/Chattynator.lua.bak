},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Vidious says: You like goods don't you? Then find them.",
["timestamp"] = 1783974072,
["id"] = "s0_526",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Arator",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Arator says: This bush was trampled--the poor wildlife here must be terrified.",
["timestamp"] = 1783974417,
["id"] = "s0_527",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
