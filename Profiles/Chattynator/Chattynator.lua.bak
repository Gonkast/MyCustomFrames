["name"] = "Gnomegoat",
["sex"] = 2,
},
["event"] = "CHAT_MSG_RAID_BOSS_WHISPER",
["type"] = "MONSTER_BOSS_WHISPER",
},
["color"] = {
["b"] = 0,
["g"] = 0.8666667342185974,
["r"] = 1,
},
["text"] = "Warning! You are trespassing. You'll be removed shortly.",
["id"] = "s0_143",
["timestamp"] = 1783889163,
},
{
