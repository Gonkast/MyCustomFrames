},
["color"] = {
["b"] = 0.250980406999588,
["g"] = 0.250980406999588,
["r"] = 1,
},
["text"] = "Halduron Brightwing yells: Silvermoon- to arms! A mass of void energy threatens the face of our city.",
["id"] = "s0_658",
["timestamp"] = 1783991369,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Halduron Brightwing",
},
["event"] = "CHAT_MSG_MONSTER_YELL",
["type"] = "MONSTER_YELL",
},
["color"] = {
["b"] = 0.250980406999588,
["g"] = 0.250980406999588,
["r"] = 1,
},
["text"] = "Halduron Brightwing yells: Positions at the main gate! We need everyone to bolster our defenses.",
["id"] = "s0_659",
["timestamp"] = 1783991376,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Halduron Brightwing",
},
["event"] = "CHAT_MSG_MONSTER_YELL",
["type"] = "MONSTER_YELL",
},
["color"] = {
["b"] = 0.250980406999588,
["g"] = 0.250980406999588,
["r"] = 1,
},
["text"] = "Halduron Brightwing yells: Here they come! Hold the line!",
["id"] = "s0_660",
["timestamp"] = 1783991559,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Halduron Brightwing",
},
["event"] = "CHAT_MSG_MONSTER_YELL",
