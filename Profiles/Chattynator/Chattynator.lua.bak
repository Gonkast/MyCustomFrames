["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Arator says: Clear the skies and rescue any survivors you can find!",
["id"] = "s0_256",
["timestamp"] = 1783902047,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Arator",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Arator says: They've sunk a ship! Throw the survivor a rope!",
["id"] = "s0_257",
["timestamp"] = 1783902232,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Arator",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Arator says: You got them all! Thank the Light!",
["id"] = "s0_258",
["timestamp"] = 1783902250,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lor'themar Theron",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lor'themar Theron says: Turalyon forgets that victory means nothing if it costs us everything in return.",
["id"] = "s0_259",
["timestamp"] = 1783902269,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Arator",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Arator says: Mount up, Gnomegoat. We must get to the gate before the Vanguard attacks!",
["id"] = "s0_260",
["timestamp"] = 1783902382,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Mehlar Dawnblade",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Mehlar Dawnblade says: Gnomegoat! The Vanguard is gathering at the north gate for a big push!",
["id"] = "s0_261",
["timestamp"] = 1783902650,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Aponi Brightmane",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Aponi Brightmane says: Gnomegoat, I thank the Light you are with us!",
["id"] = "s0_262",
["timestamp"] = 1783902654,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Nisa Cindersteel",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Nisa Cindersteel says: The Light advances!",
["id"] = "s0_263",
["timestamp"] = 1783902662,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "High Exarch Turalyon",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "High Exarch Turalyon says: Lor'themar could have handled the evacuation, Arator. You're needed with the Vanguard!",
["id"] = "s0_264",
["timestamp"] = 1783902669,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "High Exarch Turalyon",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "High Exarch Turalyon says: Vanguard of the Light, form a line! Hold this gate!",
["id"] = "s0_265",
["timestamp"] = 1783902722,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Arator",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Arator says: My father is eager to vanquish the Host, but charging forward won't be enough. We have to take out that pylon.",
["timestamp"] = 1783905084,
["id"] = "s0_266",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Nisa Cindersteel",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Nisa Cindersteel says: The Light advances!",
["timestamp"] = 1783905342,
["id"] = "s0_267",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Nisa Cindersteel",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Nisa Cindersteel says: The Light advances!",
["timestamp"] = 1783905829,
["id"] = "s0_268",
},
