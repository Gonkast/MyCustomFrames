["id"] = "s0_415",
["timestamp"] = 1783949035,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Imperatus",
},
["event"] = "CHAT_MSG_MONSTER_YELL",
["type"] = "MONSTER_YELL",
},
["color"] = {
["b"] = 0.250980406999588,
["g"] = 0.250980406999588,
["r"] = 1,
},
["text"] = "Imperatus yells: Pray to your petty well. It will not save you from Xal'atath!",
["id"] = "s0_416",
["timestamp"] = 1783949119,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["race"] = "Gnome",
["class"] = "HUNTER",
["name"] = "Gnomegoat",
["sex"] = 2,
},
["event"] = "CHAT_MSG_ACHIEVEMENT",
["type"] = "ACHIEVEMENT",
},
["color"] = {
["b"] = 0,
["g"] = 1,
["r"] = 1,
},
["text"] = "|Hplayer:Gnomegoat-Ragnaros|h[|cffaad372Gnomegoat|r]|h has earned the achievement |cffffff00|Hachievement:62191:Player-1427-0E574B9B:1:7:13:26:4294967295:4294967295:4294967295:4294967295|h[Call of the Light]|h|r!",
["id"] = "s0_417",
["timestamp"] = 1783950485,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "High Exarch Turalyon",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "High Exarch Turalyon says: The Vanguard of the Light will need quarters and supplies.",
["id"] = "s0_418",
["timestamp"] = 1783950498,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lor'themar Theron",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lor'themar Theron says: I will consider it, after I have consulted with the others.",
["id"] = "s0_419",
["timestamp"] = 1783950502,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["race"] = "Gnome",
["class"] = "HUNTER",
["name"] = "Gnomegoat",
["sex"] = 2,
},
["event"] = "CHAT_MSG_MONSTER_EMOTE",
["type"] = "MONSTER_EMOTE",
},
["color"] = {
["b"] = 0.250980406999588,
["g"] = 0.501960813999176,
["r"] = 1,
},
["text"] = "You sense a nearby Skyriding Glyph.",
["id"] = "s0_420",
["timestamp"] = 1783950521,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Grand Magister Rommath",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Grand Magister Rommath says: You are not needed!",
["timestamp"] = 1783950635,
["id"] = "s0_421",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Magister Umbric",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Magister Umbric says: That isn't your decision to make!",
["timestamp"] = 1783950638,
["id"] = "s0_422",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["class"] = "HUNTER",
["race"] = "Gnome",
["name"] = "Gnomegoat",
["sex"] = 2,
},
["event"] = "CHAT_MSG_LOOT",
["type"] = "LOOT",
},
["color"] = {
["r"] = 0,
["g"] = 0.6666666865348816,
["b"] = 0,
},
["text"] = "You receive item: |cnIQ2:|Hitem:248061::::::::80:255::11:2:13573:6652:2:9:80:28:3085:::::|h[Golden City Hatchet]|h|r",
["timestamp"] = 1783950648,
["id"] = "s0_423",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lor'themar Theron",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Lor'themar Theron says: The Sunwell holds the Voidstorm at bay for now. But its current state cannot be sustained forever.",
["timestamp"] = 1783950653,
["id"] = "s0_424",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Halduron Brightwing",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Halduron Brightwing says: And there's no telling how it could be affecting the rest of Eversong, especially the Lightbloom. We need an alternative course of action.",
["timestamp"] = 1783950659,
["id"] = "s0_425",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Magister Umbric",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Magister Umbric says: We ren'dorei can aid you in finding one. Grant us entry into Silvermoon--",
["timestamp"] = 1783950667,
["id"] = "s0_426",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Grand Magister Rommath",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Grand Magister Rommath says: Absolutely not! Your mere presence would risk defiling the Sunwell with Void magic.",
["timestamp"] = 1783950672,
["id"] = "s0_427",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Magister Umbric",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Magister Umbric says: Then it seems we have nothing more to discuss. I'll continue my research in Tranquillien, should you choose to see reason.",
["timestamp"] = 1783950679,
["id"] = "s0_428",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "High Exarch Turalyon",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "High Exarch Turalyon says: The Grand Magister is right about one thing--protecting the Sunwell is our top priority. The Vanguard of the Light will see to its defense.",
["timestamp"] = 1783950690,
["id"] = "s0_429",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lor'themar Theron",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Lor'themar Theron says: Your aid was timely and welcome, Turalyon. But remember that Silvermoon and the Sunwell belong to the sin'dorei. You are guests in our fair city.",
["timestamp"] = 1783950699,
["id"] = "s0_430",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "High Exarch Turalyon",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "High Exarch Turalyon says: Guests, allies, and saviors, Lor'themar. Rest assured that we will guard your city and your people with the full strength of the Light.",
["timestamp"] = 1783950709,
["id"] = "s0_431",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["class"] = "DRUID",
["race"] = "NightElf",
["name"] = "Muhi-Quel'Thalas",
["sex"] = 3,
},
["event"] = "CHAT_MSG_ACHIEVEMENT",
["type"] = "ACHIEVEMENT",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0,
},
["text"] = "|Hplayer:Muhi-Quel'Thalas|h[|cffff7c0aMuhi-Quel'Thalas|r]|h has earned the achievement |cffffff00|Hachievement:62273:Player-1428-0EE93A15:1:7:13:26:4294967295:4294967295:4294967295:4294967295|h[Echoes of Midnight]|h|r!",
["timestamp"] = 1783950735,
["id"] = "s0_432",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lor'themar Theron",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Lor'themar Theron says: I'll speak to the Vanguard while you get the other matters settled.",
["timestamp"] = 1783951031,
["id"] = "s0_433",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Valeera Sanguinar",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Valeera Sanguinar says: Of course--the Reliquary will lend aid wherever it's needed. Let me know if you're interested as well.",
["timestamp"] = 1783951684,
["id"] = "s0_434",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Skymaster Skyles",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Skymaster Skyles says: That surge from the Sunwell set off the dragonhawks--they know when there's danger. I've never seen them this unnerved. If the animals are this affected, what about the rest of Eversong?",
["timestamp"] = 1783951711,
["id"] = "s0_435",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Magistrix Narinth",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Magistrix Narinth says: That burst of energy from the Sunwell--it was more powerful than any magic I've ever encountered, and I am well practiced. They say that army protects us, but I heard the surge was their doing! Do they even understand what they meddle with?",
["timestamp"] = 1783951724,
["id"] = "s0_436",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Ceera",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Ceera says: The last I saw shadows descend on Quel'Danas, Arthas marched on our kingdom with his army of Scourge. Now another army marches in our streets, saying they're here for our protection... are you certain of that?",
["id"] = "s0_437",
["timestamp"] = 1783956062,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Silvermoon Citizen",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Silvermoon Citizen says: Keen eyes, my friend! I'm practicing my illusion skills for Decor Duel.\r\nYou'd make a good Seeker I'd wager.",
["id"] = "s0_438",
["timestamp"] = 1783956072,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lor'themar Theron",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lor'themar Theron says: You have already taken so many of my Blood Knights to empower the Sunwell! Quel'Thalas is largely undefended!",
["id"] = "s0_439",
["timestamp"] = 1783956150,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "General Amias Bellamy",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "General Amias Bellamy says: And I am telling you that it is still not enough. Only by the faith of our forces is the Sunwell holding back the Void.",
["id"] = "s0_440",
["timestamp"] = 1783956158,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lor'themar Theron",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lor'themar Theron says: The Sunwell must not fall.",
["id"] = "s0_441",
["timestamp"] = 1783956166,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "General Amias Bellamy",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "General Amias Bellamy says: Then make sure we have everything we need and keep enemies off our backs.",
["id"] = "s0_442",
["timestamp"] = 1783956168,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "High Exarch Turalyon",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "High Exarch Turalyon says: General, perhaps you could see to our forces at the Sunwell. I will discuss matters with the Regent Lord.",
["id"] = "s0_443",
["timestamp"] = 1783956174,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "General Amias Bellamy",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "General Amias Bellamy says: As you will it, High Exarch.",
["id"] = "s0_444",
["timestamp"] = 1783956180,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Innkeeper Jovia",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Innkeeper Jovia says: With all that has happened, that... utterly mad vortex of shadow in the sky, guests are leaving in droves. If I weren't overseeing this place, I'm not so certain I'd still be here myself. If you wish a room, it is yours.",
["id"] = "s0_445",
["timestamp"] = 1783956194,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Guard Captain Goldblade",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Guard Captain Goldblade says: The gates behind me are restricted to members of the Horde only. Avoid the red banners and trees, or there will be consequences.",
["id"] = "s0_446",
["timestamp"] = 1783956231,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["race"] = "Gnome",
["class"] = "HUNTER",
["name"] = "Gnomegoat",
["sex"] = 2,
},
["event"] = "CHAT_MSG_RAID_BOSS_WHISPER",
["type"] = "MONSTER_BOSS_WHISPER",
},
["color"] = {
["b"] = 0,
["g"] = 0.8666667342185974,
["r"] = 1,
},
["text"] = "The guards' eyes are on you. Return to neutral territory.",
["id"] = "s0_447",
["timestamp"] = 1783956243,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["race"] = "Gnome",
["class"] = "HUNTER",
["name"] = "Gnomegoat",
["sex"] = 2,
},
["event"] = "CHAT_MSG_RAID_BOSS_WHISPER",
