{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Quel'Danas Sentinel",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Quel'Danas Sentinel says: Target acquired!",
["timestamp"] = 1783906016,
["id"] = "s0_271",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Arator",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Arator says: Please forgive my father's tone. We don't always see eye-to-eye on things, to say the least.",
["timestamp"] = 1783906016,
["id"] = "s0_272",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Quel'Danas Sentinel",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Quel'Danas Sentinel says: Target acquired!",
["timestamp"] = 1783906019,
["id"] = "s0_273",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Vindicator Xayann",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Vindicator Xayann says: Activating those sentinels could shift the balance in our favor.",
["timestamp"] = 1783906024,
["id"] = "s0_274",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Quel'Danas Sentinel",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Quel'Danas Sentinel says: Target acquired!",
["timestamp"] = 1783906029,
["id"] = "s0_275",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Arator",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Arator says: High Exarch Turalyon is a vaunted battlefield commander. Though... I think he sometimes forgets how to be anything else.",
["timestamp"] = 1783906029,
["id"] = "s0_276",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Quel'Danas Sentinel",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Quel'Danas Sentinel says: Target acquired!",
["timestamp"] = 1783906033,
["id"] = "s0_277",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Arator",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Arator says: The Light will protect you!",
["timestamp"] = 1783906071,
["id"] = "s0_278",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Arator",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Arator says: You will not fall today!",
["timestamp"] = 1783906078,
["id"] = "s0_279",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Arator",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Arator says: The Light will protect you!",
["timestamp"] = 1783906091,
["id"] = "s0_280",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Arator",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Arator says: For all that creature's might, it was in such pain. When I was overcome by wrath, I lashed out in my pain. Is it the same for the Void as it is for the Light?",
["timestamp"] = 1783906094,
["id"] = "s0_281",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Quel'Danas Sentinel",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Quel'Danas Sentinel says: Target acquired!",
["timestamp"] = 1783906172,
["id"] = "s0_282",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Arator",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Arator says: The Vanguard has faith in the Light, and so do I. But I've also felt it fill me with wrath, and I... I'm not sure what to think when it does.",
["timestamp"] = 1783906172,
["id"] = "s0_283",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
