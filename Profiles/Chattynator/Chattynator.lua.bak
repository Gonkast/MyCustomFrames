},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "\"High Tides\" Ren says: We just got something special in from Vol'dun. Would you care to have a look?",
["id"] = "s0_144",
