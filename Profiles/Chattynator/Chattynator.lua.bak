},
["text"] = "The guards' eyes are on you. Return to neutral territory.",
["id"] = "s0_450",
["timestamp"] = 1783956413,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["race"] = "Gnome",
["class"] = "HUNTER",
["name"] = "Gnomegoat",
["sex"] = 2,
},
["event"] = "CHAT_MSG_RAID_BOSS_WHISPER",
