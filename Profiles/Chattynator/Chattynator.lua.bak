},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Gil says: Why do we always go the same way?",
["timestamp"] = 1783896810,
["id"] = "s0_179",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
