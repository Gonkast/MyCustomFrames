},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Alonsus Faol says: Xal'atath! If only I had found a way to destroy that accursed blade!",
["id"] = "s0_207",
["timestamp"] = 1783901336,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
