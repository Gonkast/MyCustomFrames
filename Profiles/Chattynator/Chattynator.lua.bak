},
["text"] = "Miss Danna says: Children if you would please follow me, we will now be going to see the keep where King Anduin Wrynn himself sits on his throne.",
["timestamp"] = 1783897195,
["id"] = "s0_183",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lil Timmy",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Lil Timmy says: I can't believe dad won't let me keep your sister.",
["timestamp"] = 1783897349,
["id"] = "s0_184",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lor'themar Theron",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lor'themar Theron says: Evacuating the civilians must take priority!",
["id"] = "s0_185",
["timestamp"] = 1783900076,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "High Exarch Turalyon",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "High Exarch Turalyon says: No! We need to focus on launching a counterattack!",
["id"] = "s0_186",
["timestamp"] = 1783900081,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lady Liadrin",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lady Liadrin says: We prayed for a miracle, and the Vanguard of Light answered the call. But the battle yet rages on.",
["id"] = "s0_187",
["timestamp"] = 1783900138,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "High Exarch Turalyon",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "High Exarch Turalyon says: Our forces are scattered. The Devouring Host will overwhelm us!",
["id"] = "s0_188",
["timestamp"] = 1783900164,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "High Exarch Turalyon",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "High Exarch Turalyon says: Gnomegoat, find Arator! I will rally the Vanguard and prepare an assault!",
["id"] = "s0_189",
["timestamp"] = 1783900415,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lady Liadrin",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Lady Liadrin says: Some must remain to guard the Sunwell! If it falls, all is lost!",
["id"] = "s0_190",
["timestamp"] = 1783900421,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "High Priestess Ishanah",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "High Priestess Ishanah says: By the light, Gnomegoat is with us!",
["timestamp"] = 1783900504,
["id"] = "s0_191",
},
