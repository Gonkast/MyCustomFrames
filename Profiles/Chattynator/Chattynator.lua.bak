["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Miss Danna says: Yes, that is true. Paladins and priests alike train their skills and research great truths behind the walls of the Cathedral.",
["timestamp"] = 1783897192,
["id"] = "s0_182",
},
{
