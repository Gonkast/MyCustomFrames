},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Arator says: Let's find the rest of the Vanguard. The High Exarch hates to be disappointed.",
["id"] = "s0_206",
["timestamp"] = 1783901330,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
