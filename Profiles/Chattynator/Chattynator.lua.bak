["r"] = 0,
["g"] = 0.6666666865348816,
["b"] = 0,
},
["text"] = "You receive item: |cnIQ1:|Hitem:239098::::::::80:255::11::1:28:4285:::::|h[Neighborhood Charter]|h|r",
["timestamp"] = 1783885889,
["id"] = "s0_94",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lyssabel Dawnpetal",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Lyssabel Dawnpetal says: I do enjoy a good stroll about town. Let's see what plots are available.",
["timestamp"] = 1783885944,
["id"] = "s0_95",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lyssabel Dawnpetal",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Lyssabel Dawnpetal says: And if you have any questions or find your options are too limited, please speak with me.",
["timestamp"] = 1783885951,
["id"] = "s0_96",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["class"] = "HUNTER",
["race"] = "Gnome",
["name"] = "Gnomegoat",
["sex"] = 2,
},
["event"] = "CHAT_MSG_ACHIEVEMENT",
["type"] = "ACHIEVEMENT",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0,
},
["text"] = "|Hplayer:Gnomegoat-Ragnaros|h[|cffaad372Gnomegoat|r]|h has earned the achievement |cffffff00|Hachievement:61211:Player-1427-0E574B9B:1:7:12:26:4294967295:4294967295:4294967295:4294967295|h[Welcome Home]|h|r!",
["timestamp"] = 1783886055,
["id"] = "s0_97",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lyssabel Dawnpetal",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Lyssabel Dawnpetal says: This plot is a fine choice! I look forward to seeing what you do with it.",
["timestamp"] = 1783886069,
["id"] = "s0_98",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
["player"] = {
["name"] = "Lyssabel Dawnpetal",
},
["event"] = "CHAT_MSG_MONSTER_SAY",
["type"] = "MONSTER_SAY",
},
["color"] = {
["r"] = 1,
["g"] = 1,
["b"] = 0.6235294342041016,
},
["text"] = "Lyssabel Dawnpetal says: This house is what I believe they call a 'fix-upper'. But you can gather and store away any of this clutter that you wish.",
["timestamp"] = 1783886228,
["id"] = "s0_99",
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
