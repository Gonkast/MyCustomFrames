},
["color"] = {
["b"] = 0.6235294342041016,
["g"] = 1,
["r"] = 1,
},
["text"] = "Xal'atath says: Look around you. Look above you. The Void opens your eyes to all possible futures.",
["id"] = "s0_317",
["timestamp"] = 1783909132,
},
{
["recordedBy"] = "Gnomegoat-Ragnaros",
["typeInfo"] = {
